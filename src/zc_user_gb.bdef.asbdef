projection;
strict ( 2 );
use draft;
use side effects;

define behavior for ZC_USER_GB //alias XLUser
{
  use create;
  use update;
  use delete;

  use action uploadExcelData;

  use action Activate;
  use action Edit;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _XLData { create; with draft; }
}

define behavior for ZC_DATA_GB //alias <alias_name>
{
  use update;
  use delete;

  use action processData;

  use association _XLUser { with draft; }
}